generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  invited
  suspended
}

enum SubmissionStatus {
  new
  in_review
  contacted
  resolved
  spam
}

enum ExportStatus {
  queued
  processing
  completed
  failed
}

model User {
  id                String               @id @default(uuid()) @db.Uuid
  email             String               @unique @db.VarChar(320)
  name              String?              @db.VarChar(120)
  passwordHash      String               @map("password_hash") @db.VarChar(255)
  status            UserStatus           @default(active)
  avatarUrl         String?              @map("avatar_url") @db.VarChar(500)
  lastLoginAt       DateTime?            @map("last_login_at") @db.Timestamptz(6)
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  accounts            Account[]
  sessions            Session[]
  roles               UserRole[]
  userPermissions   UserPermission[]
  assignedSubmissions FormSubmission[]   @relation("SubmissionAssignee")
  submissionNotes   SubmissionNote[]
  activityLogs      ActivityLog[]
  createdSeoOverrides SeoOverride[]      @relation("SeoOverrideCreatedBy")
  updatedSeoOverrides SeoOverride[]      @relation("SeoOverrideUpdatedBy")
  exports           Export[]
  auditEvents       AuditEvent[]

  @@index([status])
  @@map("dashboard_users")
}

model Role {
  id              String              @id @default(uuid()) @db.Uuid
  name            String              @unique @db.VarChar(80)
  slug            String              @unique @db.VarChar(80)
  description     String?
  isSystem        Boolean             @default(false) @map("is_system")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              String              @id @default(uuid()) @db.Uuid
  resource        String              @db.VarChar(80)
  action          String              @db.VarChar(80)
  description     String?
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id           String      @id @default(uuid()) @db.Uuid
  roleId       String      @map("role_id") @db.Uuid
  permissionId String      @map("permission_id") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  permissionId String        @map("permission_id") @db.Uuid
  allowed      Boolean       @default(true)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission    @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@map("user_permissions")
}

model UserRole {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  roleId    String        @map("role_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("dashboard_user_roles")
}

model FormSubmission {
  id             String           @id @default(uuid()) @db.Uuid
  source         String           @db.VarChar(80)
  formType       String           @map("form_type") @db.VarChar(80)
  name           String           @db.VarChar(120)
  email          String           @db.VarChar(320)
  phone          String?          @db.VarChar(40)
  company        String?          @db.VarChar(120)
  message        String
  status         SubmissionStatus @default(new)
  metadata       Json?
  assignedUserId String?          @map("assigned_user_id") @db.Uuid
  resolvedAt     DateTime?        @map("resolved_at") @db.Timestamptz(6)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignedUser   User?            @relation("SubmissionAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  notes          SubmissionNote[]

  @@index([status])
  @@index([email])
  @@index([createdAt(sort: Desc)])
  @@map("form_submissions")
}

model SubmissionNote {
  id           String        @id @default(uuid()) @db.Uuid
  submissionId String        @map("submission_id") @db.Uuid
  authorUserId String        @map("author_user_id") @db.Uuid
  note         String
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  submission   FormSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  authorUser   User @relation(fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([submissionId])
  @@map("submission_notes")
}

model ActivityLog {
  id          String        @id @default(uuid()) @db.Uuid
  actorUserId String?       @map("actor_user_id") @db.Uuid
  entityType  String        @map("entity_type") @db.VarChar(80)
  entityId    String        @map("entity_id") @db.VarChar(120)
  action      String        @db.VarChar(80)
  summary     String        @db.VarChar(255)
  metadata    Json?
  ipAddress   String?       @map("ip_address") @db.Inet
  userAgent   String?       @map("user_agent")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  actorUser   User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType])
  @@index([createdAt(sort: Desc)])
  @@map("activity_logs")
}

model SeoOverride {
  id              String         @id @default(uuid()) @db.Uuid
  path            String         @unique @db.VarChar(255)
  title           String?        @db.VarChar(60)
  description     String?        @db.VarChar(160)
  canonicalUrl    String?        @map("canonical_url") @db.VarChar(500)
  noIndex         Boolean        @default(false) @map("no_index")
  ogImageUrl      String?        @map("og_image_url") @db.VarChar(500)
  createdByUserId String?        @map("created_by_user_id") @db.Uuid
  updatedByUserId String?        @map("updated_by_user_id") @db.Uuid
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdByUser   User? @relation("SeoOverrideCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser   User? @relation("SeoOverrideUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("seo_overrides")
}

model Session {
  id           String        @id @default(uuid()) @db.Uuid
  sessionToken String        @unique @map("session_token") @db.VarChar(255)
  userId       String        @map("user_id") @db.Uuid
  expires      DateTime      @db.Timestamptz(6)
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("dashboard_sessions")
}

model Account {
  id                String        @id @default(uuid()) @db.Uuid
  userId            String        @map("user_id") @db.Uuid
  type              String        @db.VarChar(80)
  provider          String        @db.VarChar(80)
  providerAccountId String        @map("provider_account_id") @db.VarChar(120)
  refreshToken      String?       @map("refresh_token")
  accessToken       String?       @map("access_token")
  expiresAt         Int?          @map("expires_at")
  tokenType         String?       @map("token_type") @db.VarChar(80)
  scope             String?       @db.VarChar(255)
  idToken           String?       @map("id_token")
  sessionState      String?       @map("session_state") @db.VarChar(255)
  user              User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model VerificationToken {
  identifier String    @db.VarChar(320)
  token      String    @unique @db.VarChar(255)
  expires    DateTime  @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

model MediaAssetIndex {
  id                String    @id @default(uuid()) @db.Uuid
  contentfulAssetId String    @unique @map("contentful_asset_id") @db.VarChar(120)
  title             String?   @db.VarChar(160)
  fileName          String?   @map("file_name") @db.VarChar(255)
  mimeType          String?   @map("mime_type") @db.VarChar(120)
  fileSize          BigInt?   @map("file_size")
  width             Int?
  height            Int?
  url               String    @db.VarChar(500)
  tags              Json?
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("media_assets_index")
}

model Export {
  id                String        @id @default(uuid()) @db.Uuid
  type              String        @db.VarChar(80)
  status            ExportStatus  @default(queued)
  requestedByUserId String        @map("requested_by_user_id") @db.Uuid
  filters           Json?
  fileUrl           String?       @map("file_url") @db.VarChar(500)
  startedAt         DateTime?     @map("started_at") @db.Timestamptz(6)
  completedAt       DateTime?     @map("completed_at") @db.Timestamptz(6)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  requestedByUser   User @relation(fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("exports")
}

model AuditEvent {
  id          String         @id @default(uuid()) @db.Uuid
  actorUserId String?        @map("actor_user_id") @db.Uuid
  eventType   String         @map("event_type") @db.VarChar(80)
  targetType  String         @map("target_type") @db.VarChar(80)
  targetId    String         @map("target_id") @db.VarChar(120)
  payload     Json?
  ipAddress   String?        @map("ip_address") @db.Inet
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  actorUser   User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([targetType])
  @@index([createdAt(sort: Desc)])
  @@map("audit_events")
}
